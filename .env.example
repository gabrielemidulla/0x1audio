# Environment
COMPOSE_PROJECT_NAME=tunelink

# Postgres
POSTGRES_USER=tunelink
POSTGRES_PASSWORD=tunelink
POSTGRES_DB=tunelink
POSTGRES_PORT=5432
# Host-run API (local uv). Inside Compose, backend uses @postgres hostname.
DATABASE_URL=postgresql+asyncpg://tunelink:tunelink@127.0.0.1:5432/tunelink

# Auth (Authlib / joserfc JWT session cookies)
JWT_SECRET=tunelink-dev-jwt-secret-change-me
JWT_ISSUER=tunelink
CORS_ORIGINS=http://localhost:5173

# Apps (compose.dev / compose.prod)
BACKEND_PORT=8000
FRONTEND_PORT=5173
ML_WORKER_PORT=50051
VITE_API_BASE_URL=
# Host-run backend-worker → local ml-worker (Compose sets ml-worker:50051)
ML_WORKER_TARGET=127.0.0.1:50051

# Qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=tunelink-qdrant-dev-key
# Host-run ml-worker (Compose sets http://qdrant:6333)
QDRANT_URL=http://127.0.0.1:6333

# ML worker models (optional overrides)
# ML_MODEL_ID=OpenMuQ/MuQ-MuLan-large
# LANGUAGE_MODEL_ID=sentence-transformers/all-MiniLM-L6-v2
# ESSENTIA_MODELS_DIR=apps/ml-worker/data/models/essentia
# CUDA_VISIBLE_DEVICES=0

# Catalog ingest limits (optional; defaults support ~12 GB / 2000 tracks)
# MAX_UPLOAD_BYTES=104857600
# MAX_ZIP_BYTES=12884901888
# MAX_ZIP_UNCOMPRESSED_BYTES=12884901888
# MAX_ZIP_FILES=2000

# MinIO
MINIO_ROOT_USER=tunelink
MINIO_ROOT_PASSWORD=tunelink-dev-secret
MINIO_API_PORT=9100
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=catalog-audio
# Host-run API/worker (Compose sets minio:9000)
MINIO_ENDPOINT=127.0.0.1:9100
MINIO_ACCESS_KEY=tunelink
MINIO_SECRET_KEY=tunelink-dev-secret
