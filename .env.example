# Environment
COMPOSE_PROJECT_NAME=ox1audio

# Postgres
POSTGRES_USER=ox1audio
POSTGRES_PASSWORD=ox1audio
POSTGRES_DB=ox1audio
POSTGRES_PORT=5432
# Host-run API (local uv). Inside Compose, backend uses @postgres hostname.
DATABASE_URL=postgresql+asyncpg://ox1audio:ox1audio@127.0.0.1:5432/ox1audio

# Auth (Authlib / joserfc JWT session cookies)
JWT_SECRET=ox1audio-dev-jwt-secret-change-me
CORS_ORIGINS=http://localhost:5173

# Apps (compose.dev / compose.prod)
BACKEND_PORT=8000
FRONTEND_PORT=5173
ML_WORKER_PORT=50051
VITE_API_BASE_URL=
# Host-run backend-worker → local ml-worker (Compose sets ml-worker:50051)
ML_WORKER_TARGET=127.0.0.1:50051

# Qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=ox1audio-qdrant-dev-key
# Host-run ml-worker (Compose sets http://qdrant:6333)
QDRANT_URL=http://127.0.0.1:6333

# MinIO
MINIO_ROOT_USER=ox1audio
MINIO_ROOT_PASSWORD=ox1audio-dev-secret
MINIO_API_PORT=9100
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=catalog-audio
# Host-run API/worker (Compose sets minio:9000)
MINIO_ENDPOINT=127.0.0.1:9100
MINIO_ACCESS_KEY=ox1audio
MINIO_SECRET_KEY=ox1audio-dev-secret

# Ollama — base URL only (models/timeouts in apps/backend/config.yaml)
# OLLAMA_BASE_URL=http://127.0.0.1:11434

# Tunables: apps/backend/config.yaml and apps/ml-worker/config.yaml
#
# compose.prod.yaml requires (no defaults): JWT_SECRET, MINIO_ROOT_USER,
# MINIO_ROOT_PASSWORD, QDRANT_API_KEY
